---
import { Image } from "astro:assets";
import { siteSettings } from "../config/siteSettings";

const { access, general } = siteSettings;
const { content, style } = access;
---

<section
  id="access"
  class={`relative ${style.paddingY} overflow-hidden bg-warm-black`}
>
  <div
    class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"
  >
  </div>

  <div class="px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16 md:mb-24">
        <div class="access-reveal flex items-center justify-center gap-6">
          <span class="w-10 md:w-14 h-px bg-gold/50 flex-shrink-0"></span>
          <div class="flex flex-col items-center gap-1.5">
            <span
              class="font-sans text-[clamp(1.6rem,3.5vw,2.6rem)] font-light tracking-[0.05em] text-off-white leading-tight"
            >
              {content.sectionLabelJa}
            </span>
            <span
              class="font-display text-[10px] md:text-xs tracking-[0.35em] text-off-white/40 uppercase leading-none"
            >
              {content.sectionLabel}
            </span>
          </div>
          <span class="w-10 md:w-14 h-px bg-gold/50 flex-shrink-0"></span>
        </div>
      </div>

      <!-- Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <!-- Left: Map (Asymmetric 7 Columns) -->
        <div class="access-reveal lg:col-span-7 space-y-4">
          <!-- Google Map -->
          <div class="relative aspect-[4/3] md:aspect-[16/10] overflow-hidden rounded-sm border border-gold/10 bg-dark-surface p-1">
            <div class="relative w-full h-full overflow-hidden">
              <iframe
                src="https://maps.google.com/maps?q=EVERSHINE%20%E9%95%B7%E9%87%8E%E7%9C%8C%E5%A1%A9%E5%B0%BB%E5%B8%82%E5%BA%83%E4%B8%98%E5%A0%85%E7%9F%B32146-161&output=embed"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen={true}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                class="absolute inset-0 w-full h-full grayscale-[25%] contrast-[1.15]"
                title={content.mapTitle}></iframe>
            </div>
            {/* Corner ornaments */}
            <div class="absolute top-3 left-3 w-5 h-5 pointer-events-none">
              <span class="absolute top-0 left-0 w-full h-px bg-gold/30"></span>
              <span class="absolute top-0 left-0 h-full w-px bg-gold/30"></span>
            </div>
            <div class="absolute bottom-3 right-3 w-5 h-5 pointer-events-none">
              <span class="absolute bottom-0 right-0 w-full h-px bg-gold/30"></span>
              <span class="absolute bottom-0 right-0 h-full w-px bg-gold/30"></span>
            </div>
          </div>

          <!-- Google Maps Link Button -->
          <div class="pt-1 pl-1">
            <a
              href={content.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-xs font-sans tracking-widest text-gold hover:text-gold-light transition-colors duration-300 group"
            >
              <span>Googleマップで表示</span>
              <svg
                width="12"
                height="12"
                viewBox="0 0 14 14"
                fill="none"
                stroke="currentColor"
                stroke-width="1.2"
                class="transform transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
              >
                <path d="M1 13L13 1M13 1H5M13 1v8"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Company Info (Asymmetric 5 Columns) -->
        <div class="access-reveal lg:col-span-5 lg:pl-4">
          <!-- Company Name -->
          <div class="mb-10">
            <span
              class="font-display text-2xl md:text-3xl tracking-[0.15em] text-off-white font-light"
            >
              {general.companyName}
            </span>
            <div class="flex items-center gap-3 mt-3">
              <span class="w-8 h-px bg-gold/25"></span>
              <span
                class="font-display text-[13px] md:text-sm tracking-[0.2em] text-gold/70 italic"
                >{general.estYear}</span
              >
            </div>
          </div>

          <!-- Info Items -->
          <div class="space-y-6">
            <!-- Address -->
            <div class="flex gap-4 items-start py-1">
              <div class="w-20 md:w-24 shrink-0 flex flex-col">
                <span
                  class="font-display text-[10px] tracking-[0.25em] text-gold/75 uppercase leading-none mt-0.5"
                >
                  Address
                </span>
                <span
                  class="font-sans text-[9px] text-off-white/45 tracking-widest mt-1.5 uppercase leading-none"
                >
                  住所
                </span>
              </div>
              <div>
                <p
                  class="font-sans text-sm font-light leading-[1.8] tracking-[0.04em] text-off-white/80"
                >
                  {general.zipCode}<br />
                  {general.address}
                </p>
              </div>
            </div>

            <!-- Divider -->
            <div
              class="w-full h-px bg-gradient-to-r from-gold/10 to-transparent"
            >
            </div>

            <!-- Phone -->
            <div class="flex gap-4 items-start py-1">
              <div class="w-20 md:w-24 shrink-0 flex flex-col">
                <span
                  class="font-display text-[10px] tracking-[0.25em] text-gold/75 uppercase leading-none mt-0.5"
                >
                  Tel
                </span>
                <span
                  class="font-sans text-[9px] text-off-white/45 tracking-widest mt-1.5 uppercase leading-none"
                >
                  電話番号
                </span>
              </div>
              <div>
                <a
                  href={general.phoneNumberRaw}
                  class="font-sans text-sm font-light tracking-[0.03em] text-off-white/80 hover:text-gold transition-colors duration-300"
                >
                  {general.phoneNumber}
                </a>
              </div>
            </div>

            <!-- Divider -->
            <div
              class="w-full h-px bg-gradient-to-r from-gold/10 to-transparent"
            >
            </div>

            <!-- Hours -->
            <div class="flex gap-4 items-start py-1">
              <div class="w-20 md:w-24 shrink-0 flex flex-col">
                <span
                  class="font-display text-[10px] tracking-[0.25em] text-gold/75 uppercase leading-none mt-0.5"
                >
                  Hours
                </span>
                <span
                  class="font-sans text-[9px] text-off-white/45 tracking-widest mt-1.5 uppercase leading-none"
                >
                  営業時間
                </span>
              </div>
              <div>
                <p
                  class="font-sans text-sm font-light tracking-[0.03em] text-off-white/80"
                >
                  {general.hours}
                </p>
                <p
                  class="font-sans text-xs font-light tracking-[0.03em] text-off-white/55 mt-1"
                >
                  {general.holiday}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"
  >
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>(".access-reveal").forEach((el, i) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power3.out",
        delay: i * 0.15,
        scrollTrigger: {
          trigger: el,
          start: "top 85%",
          toggleActions: "play none none none",
        },
      },
    );
  });
</script>
