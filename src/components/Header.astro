---
import { siteSettings } from '../config/siteSettings';

const { header, general } = siteSettings;
const { logoText, navLinks, contactLabel, contactLabelJa } = header.content;
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-700 ease-out"
>
  <div class="mx-auto flex items-center justify-between px-6 md:px-12 lg:px-20 py-5 md:py-6">
    <!-- Logo -->
    <a href="#" class="relative z-10 group" aria-label={`${general.companyName} Home`}>
      <span class="font-display text-xl md:text-2xl tracking-[0.3em] text-off-white font-light uppercase">
        {logoText.first}<span class="font-medium">{logoText.second}</span>
      </span>
      <span class="block h-px w-0 group-hover:w-full bg-gold/40 transition-all duration-500 mt-0.5"></span>
    </a>

    <!-- Nav (Desktop) -->
    <nav class="hidden lg:flex items-center gap-10" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">
          <span class="text-[13px] font-sans tracking-wider text-off-white font-light">
            {link.labelJa}
          </span>
          <span class="text-[10px] font-display tracking-[0.15em] text-off-white/65 uppercase mt-0.5">
            {link.label}
          </span>
        </a>
      ))}
      <a
        href={general.phoneNumberRaw}
        class="ml-4 relative overflow-hidden bg-gradient-to-r from-accent-red via-accent-red-light to-accent-red px-5 py-1.5 flex flex-col items-center group hover:-translate-y-[1px] hover:shadow-md hover:shadow-accent-red/20 active:translate-y-0 transition-all duration-300 rounded-[2px]"
      >
        <!-- Metallic Shine Sweep -->
        <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/25 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-[1.2s] ease-out"></span>
        
        <span class="relative z-10 text-[8px] font-sans font-bold tracking-widest text-dark/80 uppercase">
          {contactLabelJa}
        </span>
        <span class="relative z-10 text-[11px] md:text-xs font-sans font-bold tracking-wide text-dark mt-0.5">
          {general.phoneNumber}
        </span>
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden relative z-10 w-8 h-8 flex flex-col justify-center items-center gap-1.5"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="menu-line w-6 h-px bg-off-white transition-all duration-300 origin-center"></span>
      <span class="menu-line w-4 h-px bg-off-white transition-all duration-300 ml-auto"></span>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-dark/98 backdrop-blur-xl flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-500 lg:hidden"
  >
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-nav-link">
        <span class="text-2xl font-sans font-light tracking-wide text-off-white">{link.labelJa}</span>
        <span class="text-[11px] font-display tracking-[0.2em] text-off-white/65 uppercase">{link.label}</span>
      </a>
    ))}
    <a
      href={general.phoneNumberRaw}
      class="mt-6 relative overflow-hidden bg-gradient-to-r from-accent-red via-accent-red-light to-accent-red px-7 py-2.5 flex flex-col items-center gap-0.5 text-dark hover:-translate-y-[1px] hover:shadow-md hover:shadow-accent-red/20 transition-all duration-300 rounded-[2px] group"
    >
      <!-- Metallic Shine Sweep -->
      <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-[1.2s] ease-out"></span>
      
      <span class="relative z-10 text-[9px] font-sans font-bold tracking-widest text-dark/70">{contactLabelJa}</span>
      <span class="relative z-10 text-sm font-sans font-bold tracking-wider text-dark">{general.phoneNumber}</span>
    </a>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-off-white);
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .nav-link:hover {
    opacity: 1;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 10%;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: width 0.4s ease;
  }

  .nav-link:hover::after {
    width: 80%;
  }

  .mobile-nav-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-off-white);
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .mobile-nav-link:hover {
    opacity: 1;
  }

  /* Header scrolled state */
  #site-header.scrolled {
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(245, 245, 240, 0.05);
  }

  #site-header.scrolled .nav-link {
    opacity: 0.85;
  }

  /* Mobile menu open state */
  #mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  #mobile-menu-btn.open .menu-line:first-child {
    transform: rotate(45deg) translateY(4px);
  }

  #mobile-menu-btn.open .menu-line:last-child {
    transform: rotate(-45deg) translateY(-3px);
    width: 1.5rem;
  }
</style>

<script>
  // Header scroll behavior
  const header = document.getElementById('site-header');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 80) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isOpen = menuBtn.classList.toggle('open');
    mobileMenu?.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuBtn?.classList.remove('open');
      mobileMenu?.classList.remove('open');
      menuBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
