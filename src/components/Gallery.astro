---
import { Image } from 'astro:assets';
import { siteSettings } from '../config/siteSettings';

const { gallery } = siteSettings;
const { content, style } = gallery;
---

<section id="gallery" class={`relative ${style.paddingY} overflow-hidden bg-warm-black`}>
  <!-- Top Ornamental Border -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>

  <div class="px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 md:mb-24">
        <div>
          <div class="gallery-reveal flex items-center gap-4">
            <span class="w-10 md:w-14 h-px bg-gold/50 flex-shrink-0"></span>
            <div class="flex flex-col gap-1.5">
              <span class="font-sans text-[clamp(1.6rem,3.5vw,2.6rem)] font-light tracking-[0.05em] text-off-white leading-tight">
                {content.sectionLabelJa}
              </span>
              <span class="font-display text-[10px] md:text-xs tracking-[0.35em] text-off-white/40 uppercase leading-none">
                {content.sectionLabel}
              </span>
            </div>
          </div>
        </div>

        <!-- Classic decorative element -->
        <div class="gallery-reveal hidden md:flex items-center gap-3 mt-6 md:mt-0">
          <span class="w-16 h-px bg-gold/15"></span>
          <span class="font-display text-[10px] tracking-[0.25em] text-gold/65 italic">{content.sideLabel}</span>
        </div>
      </div>

      <!-- Masonry-style Grid -->
      <div class={`grid ${style.gridCols} gap-3 md:gap-4 ${style.rowHeight}`}>
        {content.images.map((image, index) => (
          <div
            class:list={[
              'gallery-item group relative overflow-hidden cursor-pointer',
              image.span,
            ]}
            data-gallery-index={index}
          >
            <Image
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-110"
              widths={[400, 640, 800, 1200]}
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
              quality={80}
              loading="lazy"
            />

            <!-- Hover Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-dark/70 via-dark/10 to-transparent md:from-dark/0 md:via-transparent md:to-transparent md:group-hover:from-dark/55 md:group-hover:via-dark/20 transition-all duration-500"></div>

            <!-- Corner Ornaments (visible on hover on desktop) -->
            <div class="absolute top-4 left-4 w-6 h-6 opacity-0 md:group-hover:opacity-100 transition-opacity duration-500">
              <span class="absolute top-0 left-0 w-full h-px bg-gold/40"></span>
              <span class="absolute top-0 left-0 h-full w-px bg-gold/40"></span>
            </div>
            <div class="absolute bottom-4 right-4 w-6 h-6 opacity-0 md:group-hover:opacity-100 transition-opacity duration-500">
              <span class="absolute bottom-0 right-0 w-full h-px bg-gold/40"></span>
              <span class="absolute bottom-0 right-0 h-full w-px bg-gold/40"></span>
            </div>

            <!-- Caption -->
            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-0 md:translate-y-full md:group-hover:translate-y-0 transition-transform duration-500 ease-out">
              <span class="font-display text-xs tracking-[0.15em] text-off-white/70">
                {image.alt}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom Ornamental Border -->
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('.gallery-reveal').forEach((el) => {
    gsap.fromTo(el, { opacity: 0, y: 30 }, {
      opacity: 1, y: 0, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
    });
  });

  gsap.utils.toArray<HTMLElement>('.gallery-item').forEach((el, i) => {
    gsap.fromTo(el, { opacity: 0, y: 50 }, {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', delay: i * 0.1,
      scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' },
    });
  });
</script>
