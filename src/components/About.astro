---
import { siteSettings } from '../config/siteSettings';

const { about } = siteSettings;
const { content, style } = about;
---

<section id="about" class={`relative ${style.paddingY} overflow-hidden`}>
  <!-- Background Ornamental Elements -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>

  <!-- Large Background "Since" Text -->
  <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-[10%] select-none pointer-events-none">
    <span class={`${style.bgYearStyle} leading-none tracking-[0.05em] italic`}>
      {content.backgroundYear}
    </span>
  </div>

  <div class="px-6 md:px-12 lg:px-20">
    <div class="max-w-6xl mx-auto">
      <!-- Section Label -->
      <div class="about-reveal flex items-center gap-3 mb-16 md:mb-24">
        <span class="w-10 md:w-14 h-px bg-gold/50"></span>
        <span class="font-display text-[10px] md:text-xs tracking-[0.4em] text-gold/40 uppercase">
          {content.sectionLabel}
        </span>
      </div>

      <!-- Main Editorial Layout -->
      <div class={`grid ${style.gridCols} gap-12 lg:gap-20`}>
        <!-- Left Column: Main Heading -->
        <div class={style.leftColSpan}>
          <h2 class={`about-reveal font-display ${style.headingSize} font-light leading-[1.25] tracking-[0.02em] text-off-white`}>
            {content.heading.split('\n').map((line, idx) => (
              idx > 0 ? <><br />{line}</> : line
            ))}
          </h2>

          <!-- Classic Ornamental Divider -->
          <div class="about-reveal flex items-center gap-4 my-8 md:my-12">
            <span class="w-8 h-px bg-gold/30"></span>
            <span class="font-display text-[10px] tracking-[0.3em] text-gold/30 italic">✦</span>
            <span class="w-8 h-px bg-gold/30"></span>
          </div>

          <!-- Since Badge -->
          <div class="about-reveal">
            <span class="font-display text-xs tracking-[0.3em] text-gold/40 uppercase block mb-1">{content.sinceLabel}</span>
            <span class="font-display text-[clamp(2.5rem,5vw,4rem)] font-light text-off-white/15 italic leading-none tracking-[0.05em]">
              {content.sinceYear}
            </span>
          </div>
        </div>

        <!-- Right Column: Body Text -->
        <div class={`${style.rightColSpan} lg:pt-4`}>
          {content.paragraphs.map((p, index) => {
            const isLast = index === content.paragraphs.length - 1;
            const pClass = isLast ? style.highlightTextColor : style.textColor;
            return (
              <div class="about-reveal mt-6 first:mt-0 md:mt-8 md:first:mt-0">
                <p class={`font-sans text-sm md:text-[15px] font-light leading-[2.2] tracking-[0.04em] ${pClass}`}>
                  {p.split('\n').map((line, i) => (
                    i > 0 ? <><br />{line}</> : line
                  ))}
                </p>
              </div>
            );
          })}

          <!-- Signature-style ending -->
          <div class="about-reveal mt-12 md:mt-16 flex items-center gap-4">
            <span class="w-12 h-px bg-gold/20"></span>
            <span class="font-display text-xs tracking-[0.2em] text-gold/35 italic">{content.signature}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('.about-reveal').forEach((el, i) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        delay: i * 0.1,
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      }
    );
  });
</script>
