---
import { Image } from 'astro:assets';
import { siteSettings } from '../config/siteSettings';
import logoImg from '../images/logo.png';

const { footer, general, header } = siteSettings;
const { content, style } = footer;
---

<footer class="relative overflow-hidden">
  <!-- CTA Section -->
  <section id="cta" class={`relative ${style.ctaPaddingY}`}>
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>

    <div class="px-6 md:px-12 lg:px-20">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Classic Ornament -->
        <div class="cta-reveal flex items-center justify-center gap-4 mb-10">
          <span class="w-12 h-px bg-gold/20"></span>
          <span class="font-display text-[10px] text-gold/70">{content.ornamentSymbol}</span>
          <span class="w-12 h-px bg-gold/20"></span>
        </div>

        <!-- Heading -->
        <h2 class={`cta-reveal font-display ${style.ctaHeadingSize} font-light tracking-[0.04em] text-off-white leading-[1.4] mb-4`}>
          {content.ctaHeading}
        </h2>
        <p class="cta-reveal font-sans text-xs md:text-sm font-light tracking-[0.05em] text-off-white/60 mb-12">
          {content.ctaDescription}
        </p>

        <!-- Phone Number - Large & Prominent -->
        <div class="cta-reveal">
          <a
            href={general.phoneNumberRaw}
            class="group inline-flex flex-col items-center"
          >
            <span class="font-display text-xs md:text-sm font-medium tracking-[0.3em] text-accent-red-light/80 uppercase mb-3">{content.telLabel}</span>
            <span class="font-sans text-[clamp(2.5rem,7.5vw,5.5rem)] font-normal tracking-[0.08em] text-off-white group-hover:text-accent-red-light transition-colors duration-500 leading-none">
              {general.phoneNumber}
            </span>
            <span class="w-0 group-hover:w-full h-px bg-accent-red-light/40 transition-all duration-500 mt-4"></span>
          </a>
        </div>

        <!-- Hours -->
        <div class="cta-reveal mt-8 flex items-center justify-center gap-3">
          <span class="font-sans text-xs font-light tracking-[0.05em] text-off-white/50">
            {general.hours}（{general.holiday}）
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer Info Grid -->
  <div class="border-t border-gold/[0.07] py-16 px-6 md:px-12 lg:px-20 bg-dark-surface/10">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10">
      
      <!-- Company/Shop details -->
      <div class="flex flex-col items-center text-center gap-4">
        <div class="h-12 flex items-center justify-center">
          <Image
            src={logoImg}
            alt={general.companyName}
            class="h-10 w-auto object-contain opacity-90"
            quality={100}
          />
        </div>
        <p class="font-sans text-xs font-light text-off-white/60 leading-[2] tracking-wider mb-2">
          {general.zipCode}<br />
          {general.address}
        </p>
        <p class="font-display text-[9px] tracking-[0.15em] text-off-white/35">
          &copy; {new Date().getFullYear()} {content.copyright}
        </p>
      </div>

      <!-- Contact details -->
      <div class="flex flex-col items-center text-center gap-4">
        <h4 class="font-display text-xs tracking-[0.2em] text-gold font-medium uppercase h-12 flex items-center justify-center">
          Contact
        </h4>
        <p class="font-sans text-xs font-light text-off-white/60 leading-[2] tracking-wider">
          TEL: <a href={general.phoneNumberRaw} class="hover:text-gold transition-colors duration-300 font-sans">{general.phoneNumber}</a><br />
          営業時間: {general.hours}<br />
          定休日: {general.holiday}
        </p>
      </div>

      <!-- Menu links -->
      <div class="flex flex-col items-center text-center gap-4">
        <h4 class="font-display text-xs tracking-[0.2em] text-gold font-medium uppercase h-12 flex items-center justify-center">
          Navigation
        </h4>
        <ul class="flex flex-col items-center gap-3">
          {header.content.navLinks.map((link) => (
            <li>
              <a href={link.href} class="font-sans text-xs font-light text-off-white/60 hover:text-gold transition-colors duration-300">
                {link.labelJa} <span class="text-[9px] font-display tracking-widest text-off-white/30 uppercase ml-1">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</footer>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('.cta-reveal').forEach((el, i) => {
    gsap.fromTo(el, { opacity: 0, y: 25 }, {
      opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: i * 0.1,
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
    });
  });
</script>
