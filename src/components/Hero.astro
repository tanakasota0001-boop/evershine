---
import { Image } from 'astro:assets';
import heroImage from '../images/hero-car.png';
---

<section id="hero" class="relative w-full h-screen min-h-[700px] overflow-hidden">
  <!-- Background Image with Parallax -->
  <div id="hero-parallax" class="absolute inset-0 scale-110">
    <Image
      src={heroImage}
      alt="ガラスコーティングが施された高級車のボディ"
      class="w-full h-full object-cover"
      widths={[640, 1024, 1536, 2048]}
      sizes="100vw"
      quality={85}
      loading="eager"
    />
    <!-- Dark overlay gradient -->
    <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/60 to-dark/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-dark/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 h-full flex flex-col justify-end pb-20 md:pb-28 lg:pb-32 px-6 md:px-12 lg:px-20">
    <!-- Vertical Side Label -->
    <div class="hidden lg:flex absolute right-12 top-1/2 -translate-y-1/2 flex-col items-center gap-4">
      <span class="font-display text-[10px] tracking-[0.3em] text-gold/25 uppercase writing-vertical">
        Glass Coating Specialist
      </span>
      <span class="w-px h-16 bg-gold/15"></span>
    </div>

    <!-- Main Content: Asymmetric Left-Aligned -->
    <div class="max-w-5xl">
      <!-- Pre-heading -->
      <div id="hero-pre" class="flex items-center gap-3 mb-6 md:mb-8 opacity-0">
        <span class="w-12 md:w-16 h-px bg-gold"></span>
        <span class="font-display text-[10px] md:text-xs tracking-[0.4em] text-gold/60 uppercase">
          Est. 1990 — Shiojiri, Nagano
        </span>
      </div>

      <!-- Main Heading -->
      <h1 class="mb-6 md:mb-8">
        <span id="hero-line-1" class="block font-display text-[clamp(2.2rem,6vw,5.5rem)] font-light leading-[1.1] tracking-[0.02em] text-off-white opacity-0">
          大切な愛車に、
        </span>
        <span id="hero-line-2" class="block font-display text-[clamp(2.5rem,7vw,6.5rem)] font-light leading-[1.05] tracking-[0.02em] text-off-white mt-1 md:mt-2 opacity-0">
          最高の<em class="not-italic text-off-white/90">輝き</em>を。
        </span>
      </h1>

      <!-- Sub Heading -->
      <p id="hero-sub" class="font-sans text-sm md:text-base font-light tracking-[0.08em] text-off-white/45 max-w-md opacity-0">
        塩尻市のガラスコーティング専門店
      </p>

      <!-- CTA -->
      <div id="hero-cta" class="mt-10 md:mt-14 flex items-center gap-6 opacity-0">
        <a
          href="#services"
          class="group relative inline-flex items-center gap-3 border border-off-white/20 px-7 md:px-9 py-3.5 md:py-4 text-xs tracking-[0.2em] uppercase text-off-white overflow-hidden transition-all duration-600 hover:border-off-white/40"
        >
          <span class="absolute inset-0 bg-off-white translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></span>
          <span class="relative group-hover:text-dark transition-colors duration-500">View Services</span>
          <svg class="relative w-3 h-3 group-hover:text-dark transition-colors duration-500" fill="none" viewBox="0 0 12 12" stroke="currentColor" stroke-width="1">
            <path d="M2 6h8M7 3l3 3-3 3" />
          </svg>
        </a>
        <a
          href="tel:0263532276"
          class="text-[11px] tracking-[0.15em] text-off-white/35 hover:text-off-white/70 transition-colors duration-300 uppercase"
        >
          0263-53-2276
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div id="hero-scroll-indicator" class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0">
    <span class="font-display text-[9px] tracking-[0.3em] text-gold/30 uppercase">Scroll</span>
    <div class="w-px h-10 relative overflow-hidden">
      <div class="scroll-line absolute w-full h-full bg-off-white/20"></div>
      <div class="scroll-line-active absolute w-full bg-off-white/60" style="height: 40%; animation: scrollDown 2s ease-in-out infinite;"></div>
    </div>
  </div>
</section>

<style>
  .writing-vertical {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  @keyframes scrollDown {
    0% {
      top: -40%;
    }
    100% {
      top: 100%;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Wait for page load
  window.addEventListener('load', () => {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Pre-heading
    tl.to('#hero-pre', {
      opacity: 1,
      x: 0,
      duration: 0.8,
      delay: 0.3,
    }, 0);

    tl.from('#hero-pre', {
      x: -30,
      duration: 0.8,
      delay: 0.3,
    }, 0);

    // Main heading line 1 - character by character
    const line1 = document.getElementById('hero-line-1');
    if (line1) {
      const text1 = line1.textContent || '';
      line1.innerHTML = '';
      line1.style.opacity = '1';
      text1.split('').forEach((char) => {
        const span = document.createElement('span');
        span.textContent = char;
        span.style.display = 'inline-block';
        span.style.opacity = '0';
        span.style.transform = 'translateY(40px)';
        if (char === ' ') span.style.width = '0.3em';
        line1.appendChild(span);
      });

      tl.to(line1.children, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.04,
        ease: 'power2.out',
      }, 0.6);
    }

    // Main heading line 2 - character by character
    const line2 = document.getElementById('hero-line-2');
    if (line2) {
      const text2 = line2.textContent || '';
      line2.innerHTML = '';
      line2.style.opacity = '1';
      text2.split('').forEach((char) => {
        const span = document.createElement('span');
        span.textContent = char;
        span.style.display = 'inline-block';
        span.style.opacity = '0';
        span.style.transform = 'translateY(40px)';
        if (char === ' ') span.style.width = '0.3em';
        line2.appendChild(span);
      });

      tl.to(line2.children, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.04,
        ease: 'power2.out',
      }, 1.0);
    }

    // Sub heading
    tl.to('#hero-sub', {
      opacity: 1,
      y: 0,
      duration: 0.8,
    }, 1.4);

    tl.from('#hero-sub', {
      y: 20,
      duration: 0.8,
    }, 1.4);

    // CTA
    tl.to('#hero-cta', {
      opacity: 1,
      y: 0,
      duration: 0.8,
    }, 1.7);

    tl.from('#hero-cta', {
      y: 20,
      duration: 0.8,
    }, 1.7);

    // Scroll indicator
    tl.to('#hero-scroll-indicator', {
      opacity: 1,
      duration: 1,
    }, 2.2);

    // Parallax on scroll
    gsap.to('#hero-parallax', {
      yPercent: 20,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 0.5,
      },
    });

    // Fade out hero content on scroll
    gsap.to('#hero .relative.z-10', {
      opacity: 0,
      y: -60,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: '60% top',
        end: 'bottom top',
        scrub: 0.5,
      },
    });
  });
</script>
