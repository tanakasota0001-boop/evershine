---
import { Image } from "astro:assets";
import { siteSettings } from "../config/siteSettings";

const { hero } = siteSettings;
const { content, style } = hero;
---

<section
  id="hero"
  class="relative w-full h-screen min-h-[550px] md:min-h-[700px] overflow-hidden"
>
  <!-- Background Image with Parallax -->
  <div id="hero-parallax" class="absolute inset-0 scale-110">
    <Image
      src={content.image}
      alt={content.imageAlt}
      class="w-full h-full object-cover"
      widths={[640, 1024, 1536, 2048]}
      sizes="100vw"
      quality={85}
      loading="eager"
    />
    <!-- Dark overlay gradient -->
    <div
      class={`absolute inset-0 bg-gradient-to-r ${style.gradientOverlayLeft}`}
    >
    </div>
    <div
      class={`absolute inset-0 bg-gradient-to-t ${style.gradientOverlayBottom}`}
    >
    </div>
  </div>

  <!-- Content -->
  <div
    class={`relative z-10 h-full flex flex-col justify-center md:justify-end ${style.paddingBottom} px-6 md:px-12 lg:px-20 ${style.textAlign === "text-center" ? "items-center" : style.textAlign === "text-right" ? "items-end" : ""}`}
  >


    <!-- Main Content: Asymmetric Left-Aligned -->
    <div class={`${style.maxWidth} ${style.textAlign} flex items-stretch gap-6 md:gap-8`}>
      <!-- Gold Vertical Accent Line -->
      <div
        id="hero-line-accent"
        class="w-px bg-gradient-to-b from-gold via-gold/40 to-transparent opacity-0 origin-top shrink-0"
        style="transform: scaleY(0);"
      ></div>

      <div>
        <!-- Main Heading -->
        <h1 class="mb-6 md:mb-8">
          <span
            id="hero-line-1"
            class={`block font-display ${style.titleLine1Size} font-light leading-[1.1] tracking-[0.02em] ${style.titleColor} opacity-0`}
          >
            {content.line1}
          </span>
          <span
            id="hero-line-2"
            class={`block font-display ${style.titleLine2Size} font-light leading-[1.05] tracking-[0.02em] ${style.titleColor} mt-1 md:mt-2 opacity-0`}
            data-highlight={content.highlightText}
            data-highlight-class={style.highlightColor}
          >
            {content.line2}
          </span>
        </h1>

        <!-- Sub Heading -->
        <p
          id="hero-sub"
          class={`font-sans ${style.subtitleSize} font-light tracking-[0.08em] ${style.subtitleColor} max-w-lg opacity-0 ${style.textAlign === "text-center" ? "mx-auto" : style.textAlign === "text-right" ? "ml-auto" : ""}`}
        >
          {content.subtitle}
        </p>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div
    id="hero-scroll-indicator"
    class="absolute bottom-24 md:bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0"
  >
    <span
      class="font-display text-[9px] tracking-[0.3em] text-gold/70 uppercase"
      >{content.scrollText}</span
    >
    <div class="w-px h-10 relative overflow-hidden">
      <div class="scroll-line absolute w-full h-full bg-off-white/20"></div>
      <div
        class="scroll-line-active absolute w-full bg-off-white/60"
        style="height: 40%; animation: scrollDown 2s ease-in-out infinite;"
      >
      </div>
    </div>
  </div>
</section>

<style>
  .writing-vertical {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  @keyframes scrollDown {
    0% {
      top: -40%;
    }
    100% {
      top: 100%;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Wait for page load
  window.addEventListener("load", () => {
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    // Pre-heading
    tl.to(
      "#hero-pre",
      {
        opacity: 1,
        x: 0,
        duration: 0.8,
        delay: 0.3,
      },
      0,
    );

    tl.from(
      "#hero-pre",
      {
        x: -30,
        duration: 0.8,
        delay: 0.3,
      },
      0,
    );

    // Main heading line 1 - character by character
    const line1 = document.getElementById("hero-line-1");
    if (line1) {
      const text1 = line1.textContent || "";
      line1.innerHTML = "";
      line1.style.opacity = "1";
      text1
        .trim()
        .split("")
        .forEach((char) => {
          const span = document.createElement("span");
          span.textContent = char;
          span.style.display = "inline-block";
          span.style.opacity = "0";
          span.style.transform = "translateY(40px)";
          if (char === " ") span.style.width = "0.3em";
          line1.appendChild(span);
        });

      tl.to(
        line1.children,
        {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.04,
          ease: "power2.out",
        },
        0.6,
      );
    }

    // Main heading line 2 - character by character
    const line2 = document.getElementById("hero-line-2");
    if (line2) {
      const text2 = line2.textContent || "";
      const highlight = line2.getAttribute("data-highlight") || "";
      const highlightClass =
        line2.getAttribute("data-highlight-class") || "text-off-white/90";
      line2.innerHTML = "";
      line2.style.opacity = "1";
      text2
        .trim()
        .split("")
        .forEach((char) => {
          const span = document.createElement("span");
          span.textContent = char;
          span.style.display = "inline-block";
          span.style.opacity = "0";
          span.style.transform = "translateY(40px)";
          if (char === " ") span.style.width = "0.3em";
          if (highlight && highlight.includes(char)) {
            highlightClass.split(" ").forEach((cls) => {
              if (cls) span.classList.add(cls);
            });
          }
          line2.appendChild(span);
        });

      tl.to(
        line2.children,
        {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.04,
          ease: "power2.out",
        },
        1.0,
      );
    }

    // Gold Vertical Accent Line
    tl.to(
      "#hero-line-accent",
      {
        opacity: 1,
        scaleY: 1,
        duration: 1.2,
        ease: "power3.out",
      },
      0.5
    );

    // Sub heading
    tl.to(
      "#hero-sub",
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
      },
      1.4,
    );

    tl.from(
      "#hero-sub",
      {
        y: 20,
        duration: 0.8,
      },
      1.4,
    );

    // CTA
    tl.to(
      "#hero-cta",
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
      },
      1.7,
    );

    tl.from(
      "#hero-cta",
      {
        y: 20,
        duration: 0.8,
      },
      1.7,
    );

    // Scroll indicator
    tl.to(
      "#hero-scroll-indicator",
      {
        opacity: 1,
        duration: 1,
      },
      2.2,
    );

    // Parallax on scroll
    gsap.to("#hero-parallax", {
      yPercent: 20,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero",
        start: "top top",
        end: "bottom top",
        scrub: 0.5,
      },
    });

    // Fade out hero content on scroll
    gsap.to("#hero .relative.z-10", {
      opacity: 0,
      y: -60,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero",
        start: "60% top",
        end: "bottom top",
        scrub: 0.5,
      },
    });
  });
</script>
