---
import { Image } from 'astro:assets';
import { siteSettings } from '../config/siteSettings';

const { services } = siteSettings;
const { content, style } = services;
---

<section id="services" class={`relative ${style.paddingY} overflow-hidden`}>
  <!-- Section Header -->
  <div class="px-6 md:px-12 lg:px-20 mb-16 md:mb-24 lg:mb-32">
    <div class="max-w-7xl mx-auto">
      <div class="service-reveal flex items-center gap-4 mb-12 md:mb-16 lg:mb-20">
        <span class="w-10 md:w-14 h-px bg-gold/50 flex-shrink-0"></span>
        <div class="flex flex-col gap-1.5">
          <span class="font-sans text-[clamp(1.6rem,3.5vw,2.6rem)] font-light tracking-[0.05em] text-off-white leading-tight">
            {content.sectionLabelJa}
          </span>
          <span class="font-display text-[10px] md:text-xs tracking-[0.35em] text-off-white/40 uppercase leading-none">
            {content.sectionLabel}
          </span>
        </div>
      </div>
      <h2 class="service-reveal">
        <span class={`block font-display ${style.headingSize} font-light tracking-[0.02em] text-off-white leading-[1.15]`}>
          {content.headingLine1}
        </span>
        <span class={`block font-display ${style.headingSize} font-light tracking-[0.02em] text-off-white/75 leading-[1.15] mt-1`}>
          {content.headingLine2}
        </span>
      </h2>
    </div>
  </div>

  <!-- Services Grid -->
  <div class="px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <div class={`grid ${style.gridCols} gap-[1px] bg-off-white/[0.03]`}>
        {content.items.map((service, index) => (
          <article
            class="service-card group relative overflow-hidden bg-dark cursor-pointer transition-all duration-300 active:scale-[0.98] active:brightness-95"
            data-service-index={index}
          >
            <!-- Image Background -->
            <div class="relative aspect-[5/4] md:aspect-[3/2] overflow-hidden">
              <Image
                src={service.image}
                alt={service.titleJp}
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-110 group-[.touched]:scale-110"
                widths={[400, 640, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                quality={80}
                loading="lazy"
              />
              <!-- Overlay Gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-dark/95 via-dark/65 to-transparent opacity-80 group-hover:opacity-95 group-[.touched]:opacity-95 transition-opacity duration-700"></div>

              <!-- Shine Effect -->
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 group-[.touched]:opacity-100 transition-opacity duration-700">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.04] to-transparent -translate-x-full group-hover:translate-x-full group-[.touched]:translate-x-full transition-transform duration-[1.5s] ease-out"></div>
              </div>
            </div>

            <!-- Content Overlay -->
            <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-6 md:p-8 lg:p-10">
              <!-- Number -->
              <span class="font-display text-xs md:text-sm tracking-[0.3em] text-gold mb-1.5 block transition-colors duration-500 group-hover:text-gold-light group-[.touched]:text-gold-light">
                {service.number}
              </span>

              <!-- Title English -->
              <h3 class={`font-display ${style.cardTitleSize} font-medium tracking-[0.08em] text-off-white mb-0.5 transition-all duration-500 group-hover:text-gold-light group-hover:-translate-y-1 group-[.touched]:text-gold-light group-[.touched]:-translate-y-1`}>
                {service.title}
              </h3>

              <!-- Title Japanese -->
              <span class="font-sans text-xs md:text-[13px] font-medium tracking-[0.12em] text-warm-gray mb-0 transition-colors duration-500 group-hover:text-off-white group-[.touched]:text-off-white">
                {service.titleJp}
              </span>

              <!-- Divider Line (Responsive: always visible on mobile, grows on hover/touch) -->
              <span class="w-8 h-[2px] bg-gold my-2.5 block transition-all duration-500 origin-left group-hover:w-16 group-[.touched]:w-16"></span>

              <!-- Description Block (glassmorphic, high-contrast box always visible on mobile, hover/touch-revealed on desktop) -->
              <div class="service-desc-container overflow-hidden max-w-xs">
                <p class="font-sans text-[11px] sm:text-xs md:text-sm font-light leading-relaxed text-off-white/90 whitespace-pre-line">
                  {service.description}
                </p>
              </div>
            </div>

            <!-- Bottom Border Accent -->
            <div class="absolute bottom-0 left-0 w-0 h-px bg-gold group-hover:w-full group-[.touched]:w-full transition-all duration-700 ease-out"></div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Decorative Line -->
  <div class="absolute top-0 left-6 md:left-12 lg:left-20 w-px h-full bg-gold/[0.04]"></div>
</section>

<style>
  /* Mobile layout: always visible, styled box with gold border and dark backing */
  .service-desc-container {
    max-height: 120px;
    opacity: 1;
    margin-top: 0.5rem;
    padding: 0.375rem 0.5rem 0.375rem 0.875rem;
    border-left: 2px solid rgba(204, 166, 98, 0.5); /* gold/50 */
    background-color: rgba(10, 10, 10, 0.45);
    backdrop-filter: blur(4px);
    transition: all 0.5s ease-out;
  }

  /* Desktop layout: hidden initially, slides open on hover/touch */
  @media (min-width: 768px) {
    .service-desc-container {
      max-height: 0;
      opacity: 0;
      margin-top: 0;
      padding-top: 0;
      padding-bottom: 0;
      border-left-width: 0;
      background-color: transparent;
      backdrop-filter: none;
    }

    .service-card:hover .service-desc-container,
    .service-card.touched .service-desc-container {
      max-height: 120px;
      opacity: 1;
      margin-top: 0.75rem;
      padding: 0.375rem 0.5rem 0.375rem 0.875rem;
      border-left: 2px solid var(--color-gold);
      background-color: rgba(10, 10, 10, 0.45);
      backdrop-filter: blur(4px);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Section header reveal
  gsap.utils.toArray<HTMLElement>('.service-reveal').forEach((el) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  // Service cards staggered reveal
  const cards = gsap.utils.toArray<HTMLElement>('.service-card');
  cards.forEach((card, i) => {
    gsap.fromTo(
      card,
      {
        opacity: 0,
        y: 60,
      },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        delay: i * 0.15,
        scrollTrigger: {
          trigger: card,
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  // Touch interactions for mobile devices
  cards.forEach((card) => {
    card.addEventListener('touchstart', () => {
      card.classList.add('touched');
    }, { passive: true });
    card.addEventListener('touchend', () => {
      setTimeout(() => {
        card.classList.remove('touched');
      }, 250);
    }, { passive: true });
    card.addEventListener('touchcancel', () => {
      card.classList.remove('touched');
    }, { passive: true });
  });
</script>
