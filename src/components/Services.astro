---
import { Image } from 'astro:assets';
import { siteSettings } from '../config/siteSettings';

const { services } = siteSettings;
const { content, style } = services;
---

<section id="services" class={`relative ${style.paddingY} overflow-hidden`}>
  <!-- Section Header -->
  <div class="px-6 md:px-12 lg:px-20 mb-16 md:mb-24 lg:mb-32">
    <div class="max-w-7xl mx-auto">
      <div class="service-reveal flex items-center gap-3 mb-5">
        <span class="w-10 md:w-14 h-px bg-gold/50"></span>
        <span class="font-display text-[10px] md:text-xs tracking-[0.4em] text-gold/40 uppercase">
          {content.sectionLabel}
        </span>
      </div>
      <h2 class="service-reveal">
        <span class={`block font-display ${style.headingSize} font-light tracking-[0.02em] text-off-white leading-[1.15]`}>
          {content.headingLine1}
        </span>
        <span class={`block font-display ${style.headingSize} font-light tracking-[0.02em] text-off-white/60 leading-[1.15] mt-1`}>
          {content.headingLine2}
        </span>
      </h2>
    </div>
  </div>

  <!-- Services Grid -->
  <div class="px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <div class={`grid ${style.gridCols} gap-[1px] bg-off-white/[0.03]`}>
        {content.items.map((service, index) => (
          <article
            class="service-card group relative overflow-hidden bg-dark cursor-pointer"
            data-service-index={index}
          >
            <!-- Image Background -->
            <div class="relative aspect-[4/3] md:aspect-[3/2] overflow-hidden">
              <Image
                src={service.image}
                alt={service.titleJp}
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-110"
                widths={[400, 640, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                quality={80}
                loading="lazy"
              />
              <!-- Overlay Gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/50 to-transparent opacity-70 group-hover:opacity-85 transition-opacity duration-700"></div>

              <!-- Shine Effect -->
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.04] to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-[1.5s] ease-out"></div>
              </div>
            </div>

            <!-- Content Overlay -->
            <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-8 lg:p-10">
              <!-- Number -->
              <span class="font-display text-[10px] tracking-[0.3em] text-off-white/20 mb-3 block transition-colors duration-500 group-hover:text-gold/60">
                {service.number}
              </span>

              <!-- Title English -->
              <h3 class={`font-display ${style.cardTitleSize} font-light tracking-[0.05em] text-off-white mb-1 transition-transform duration-500 group-hover:-translate-y-1`}>
                {service.title}
              </h3>

              <!-- Title Japanese -->
              <span class="text-[11px] md:text-xs tracking-[0.1em] text-off-white/40 mb-0 transition-all duration-500 group-hover:text-off-white/60">
                {service.titleJp}
              </span>

              <!-- Description (revealed on hover) -->
              <p class="text-xs md:text-sm font-light leading-relaxed text-off-white/0 max-w-xs mt-0 max-h-0 overflow-hidden transition-all duration-700 ease-out group-hover:text-off-white/50 group-hover:mt-3 group-hover:max-h-24">
                {service.description}
              </p>

              <!-- Arrow -->
              <div class="absolute bottom-6 right-6 md:bottom-8 md:right-8 w-8 h-8 flex items-center justify-center opacity-0 translate-y-2 group-hover:opacity-60 group-hover:translate-y-0 transition-all duration-500">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1" class="text-off-white">
                  <path d="M1 13L13 1M13 1H5M13 1v8" />
                </svg>
              </div>
            </div>

            <!-- Bottom Border Accent -->
            <div class="absolute bottom-0 left-0 w-0 h-px bg-gold group-hover:w-full transition-all duration-700 ease-out"></div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Decorative Line -->
  <div class="absolute top-0 left-6 md:left-12 lg:left-20 w-px h-full bg-gold/[0.04]"></div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Section header reveal
  gsap.utils.toArray<HTMLElement>('.service-reveal').forEach((el) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  // Service cards staggered reveal
  const cards = gsap.utils.toArray<HTMLElement>('.service-card');
  cards.forEach((card, i) => {
    gsap.fromTo(
      card,
      {
        opacity: 0,
        y: 60,
      },
      {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        delay: i * 0.15,
        scrollTrigger: {
          trigger: card,
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
      }
    );
  });
</script>
